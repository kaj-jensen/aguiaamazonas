---
import TourCard from './TourCard.astro';
import { tours } from '../data/tours';

interface Props { lang?: 'en' | 'pt-BR' }
const { lang = 'en' } = Astro.props;
const isPt = lang === 'pt-BR';
const coreTour = tours.find((tour) => tour.slug === 'amazon-jungle-survival-experience');
const durationBand = (slug: string) => {
  if (slug === 'full-day-tour-from-manaus') return 'day';
  if (slug.includes('2-day') || slug.includes('3-days') || slug.includes('3-days-2') || slug.includes('cruise-3')) return 'short';
  if (slug.includes('4-days') || slug.includes('cruise-4') || slug.includes('survival')) return 'medium';
  return 'long';
};
const paceBand = (slug: string) => {
  if (slug.includes('survival') || slug.includes('safari')) return 'adventure';
  if (slug.includes('cruise') || slug.includes('full-day')) return 'active';
  return 'relaxed';
};
---

<section class="experience-section" id={isPt ? 'experiencias' : 'experiences'}>
  <div class="section-head catalogue-head wrap">
    <div><p class="eyebrow">{isPt ? 'Escolha sua experiência' : 'Choose your experience'}</p><h2>{isPt ? 'Encontre sua viagem pela Amazônia.' : 'Find your Amazon journey.'}</h2></div>
    <p>{isPt ? 'Compare passeios de um dia, pousadas, cruzeiros e expedições.' : 'Compare day tours, lodge stays, cruises and expeditions.'}</p>
  </div>

  {coreTour && (
    <section class="core-experience wrap" id="core-experience">
      <header>
        <div>
          <p class="eyebrow">{isPt ? 'Experiência essencial' : 'Águia signature journey'}</p>
          <h3>{isPt ? 'Viva a floresta de verdade.' : 'Learn to live with the forest.'}</h3>
        </div>
        <p>{isPt ? 'Uma experiência privativa de sobrevivência, adaptada ao seu preparo e conduzida pessoalmente por Antonio.' : 'A private survival experience shaped around your ability and personally led by Antonio.'}</p>
      </header>
      <div class="journey-cards single core-card">
        <TourCard tour={coreTour} lang={lang} signature />
      </div>
    </section>
  )}

  <section class="tour-finder wrap" aria-labelledby="tour-finder-title">
    <div class="finder-heading">
      <div><p class="eyebrow">{isPt ? 'Encontre a viagem certa' : 'Find your fit'}</p><h3 id="tour-finder-title">{isPt ? 'Compare todas as experiências.' : 'Compare every experience.'}</h3></div>
      <p id="tour-result-count" aria-live="polite">{tours.length} {isPt ? 'experiências' : 'experiences'}</p>
    </div>
    <div class="finder-controls" data-tour-finder>
      <label>
        <span>{isPt ? 'Pesquisar' : 'Search'}</span>
        <input type="search" name="query" placeholder={isPt ? 'Ex.: botos, canoa ou cachoeira' : 'Try dolphins, canoe or waterfall'} />
      </label>
      <label>
        <span>{isPt ? 'Tipo de viagem' : 'Journey type'}</span>
        <select name="kind">
          <option value="all">{isPt ? 'Todos os tipos' : 'All types'}</option>
          <option value="day">{isPt ? 'Passeio de um dia' : 'Day tour'}</option>
          <option value="lodge">{isPt ? 'Pousada na floresta' : 'Jungle lodge'}</option>
          <option value="cruise">{isPt ? 'Cruzeiro fluvial' : 'River cruise'}</option>
          <option value="wild">{isPt ? 'Expedição' : 'Expedition'}</option>
        </select>
      </label>
      <label>
        <span>{isPt ? 'Duração' : 'Duration'}</span>
        <select name="duration">
          <option value="all">{isPt ? 'Qualquer duração' : 'Any duration'}</option>
          <option value="day">{isPt ? 'Um dia' : 'One day'}</option>
          <option value="short">{isPt ? '2–3 dias' : '2–3 days'}</option>
          <option value="medium">{isPt ? '4–5 dias' : '4–5 days'}</option>
          <option value="long">{isPt ? '6 dias ou mais' : '6+ days'}</option>
        </select>
      </label>
      <label>
        <span>{isPt ? 'Ritmo' : 'Pace'}</span>
        <select name="pace">
          <option value="all">{isPt ? 'Qualquer ritmo' : 'Any pace'}</option>
          <option value="relaxed">{isPt ? 'Tranquilo' : 'Relaxed'}</option>
          <option value="active">{isPt ? 'Ativo' : 'Active'}</option>
          <option value="adventure">{isPt ? 'Aventura intensa' : 'Deep adventure'}</option>
        </select>
      </label>
      <button type="button" data-reset>{isPt ? 'Limpar filtros' : 'Clear filters'}</button>
    </div>
    <div class="finder-grid">
      {tours.map((tour) => (
        <div
          class="tour-filter-item"
          data-kind={tour.kind}
          data-duration={durationBand(tour.slug)}
          data-pace={paceBand(tour.slug)}
          data-search={`${tour.name} ${tour.ptName} ${tour.summary} ${tour.ptSummary} ${tour.highlights.join(' ')} ${tour.ptHighlights.join(' ')}`.toLocaleLowerCase()}
        >
          <TourCard tour={tour} lang={lang} />
        </div>
      ))}
    </div>
    <p class="finder-empty" hidden>{isPt ? 'Nenhuma viagem corresponde a esses filtros. Limpe um filtro ou fale com Antonio para criar um roteiro personalizado.' : 'No journey matches those filters. Clear a filter or ask Antonio to shape a custom route.'}</p>
  </section>
</section>

<style is:global>
  .experience-section {
    padding-top: 46px;
  }

  .catalogue-head {
    grid-template-columns: minmax(0, 1.5fr) minmax(280px, .7fr);
    gap: 40px;
    align-items: center;
    margin-bottom: 24px;
  }

  .catalogue-head .eyebrow {
    margin-bottom: 8px;
  }

  .catalogue-head h2 {
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1.05;
  }

  .catalogue-head > p {
    margin: 0;
    font-size: 16px;
  }

  .core-experience {
    margin-top: 34px;
    padding: 34px;
    border-radius: 28px;
    background: #0b3026;
    color: #f6f0e3;
  }

  .core-experience > header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, .72fr);
    gap: 36px;
    align-items: end;
    margin-bottom: 24px;
  }

  .core-experience > header h3 {
    margin: 6px 0 0;
    color: #fffaf0;
    font-size: clamp(34px, 4vw, 58px);
    line-height: 1;
  }

  .core-experience > header > p {
    margin: 0;
    color: rgba(255, 255, 255, .78);
    font-size: 17px;
  }

  .core-experience .tour-card {
    border-radius: 20px;
    overflow: hidden;
  }

  .core-experience .tour-copy h3 {
    color: var(--ink);
  }

  .signature-pitch {
    margin-top: 20px;
  }

  .signature-pitch > p {
    margin: 0;
    color: #52615b;
    line-height: 1.65;
  }

  .signature-pitch ul {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin: 22px 0 0;
    padding: 0;
    list-style: none;
  }

  .signature-pitch li {
    position: relative;
    padding: 13px 12px 13px 30px;
    border-radius: 10px;
    background: #eef2e8;
    color: #183c31;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.35;
  }

  .signature-pitch li::before {
    content: '✓';
    position: absolute;
    left: 12px;
    color: #16865c;
  }

  .core-jump {
    color: #ef7d4f;
  }

  .tour-finder {
    padding-top: 58px;
  }

  .finder-heading {
    display: flex;
    justify-content: space-between;
    gap: 30px;
    align-items: end;
    margin-bottom: 22px;
  }

  .finder-heading h3 {
    margin: 0;
    font-family: var(--display);
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1.02;
  }

  .finder-heading > p {
    margin: 0 0 6px;
    color: #66736d;
    font-weight: 700;
  }

  .finder-controls {
    display: grid;
    grid-template-columns: minmax(250px, 1.5fr) repeat(3, minmax(150px, .75fr)) auto;
    gap: 12px;
    padding: 20px;
    border: 1px solid #cbc7ba;
    border-radius: 18px;
    background: rgba(255, 255, 255, .55);
  }

  .finder-controls label {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .finder-controls label span {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #5d6a64;
  }

  .finder-controls input,
  .finder-controls select {
    width: 100%;
    min-height: 48px;
    border: 1px solid #c9c5b8;
    border-radius: 8px;
    background: #fff;
    color: var(--ink);
    font: inherit;
    font-size: 14px;
    padding: 0 13px;
  }

  .finder-controls button {
    align-self: end;
    min-height: 48px;
    padding: 0 17px;
    border: 0;
    border-radius: 8px;
    background: var(--ink);
    color: #fff;
    font: inherit;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
  }

  .finder-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px;
    margin-top: 26px;
  }

  .tour-filter-item,
  .tour-filter-item .tour-card {
    min-width: 0;
    height: 100%;
  }

  .tour-filter-item .tour-card {
    display: flex;
    flex-direction: column;
    box-shadow: 0 12px 35px rgba(25, 36, 30, .07);
  }

  .tour-filter-item .tour-copy {
    display: flex;
    flex: 1;
    flex-direction: column;
  }

  .tour-filter-item .tour-copy > p:not(.eyebrow) {
    flex: 1;
    min-height: 0;
  }

  .tour-filter-item[hidden] {
    display: none;
  }

  .finder-empty {
    margin: 26px 0 0;
    padding: 28px;
    border: 1px dashed #a8aaa0;
    text-align: center;
    color: #59665f;
  }

  @media (min-width: 901px) {
    .core-card.journey-cards.single {
      grid-template-columns: minmax(0, 1fr);
    }

    .core-card .tour-card {
      display: grid;
      grid-template-columns: minmax(360px, .9fr) minmax(0, 1.1fr);
      height: auto;
      min-height: 390px;
    }

    .core-card .tour-image {
      height: 100%;
      min-height: 390px;
      aspect-ratio: auto;
    }

    .core-card .tour-copy {
      padding: clamp(32px, 4vw, 58px);
      justify-content: center;
    }

    .core-card .tour-copy h3 {
      font-size: clamp(34px, 3.2vw, 50px);
    }

    .core-card .tour-copy > p:not(.eyebrow) {
      flex: 0;
      font-size: 17px;
      line-height: 1.65;
    }

    .core-card .tour-meta {
      margin-top: 24px;
    }
  }

  @media (max-width: 900px) {
    .experience-section {
      padding-top: 38px;
    }

    .catalogue-head {
      gap: 10px;
      margin-bottom: 20px;
    }

    .catalogue-head h2 {
      font-size: 38px;
    }

    .core-experience {
      margin-top: 24px;
      padding: 22px;
    }

    .core-experience > header {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .signature-pitch ul {
      grid-template-columns: 1fr;
    }

    .tour-finder {
      padding-top: 42px;
    }

    .finder-heading {
      align-items: start;
      flex-direction: column;
      gap: 8px;
    }

    .finder-controls,
    .finder-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  document.querySelectorAll('[data-tour-finder]').forEach((form) => {
    const section = form.closest('.tour-finder');
    const items = [...section.querySelectorAll('.tour-filter-item')];
    const count = section.querySelector('#tour-result-count');
    const empty = section.querySelector('.finder-empty');
    const query = form.querySelector('[name="query"]');
    const selects = [...form.querySelectorAll('select')];
    const update = () => {
      const term = query.value.trim().toLocaleLowerCase();
      const values = Object.fromEntries(selects.map((select) => [select.name, select.value]));
      let visible = 0;
      items.forEach((item) => {
        const matches =
          (!term || item.dataset.search.includes(term)) &&
          (values.kind === 'all' || item.dataset.kind === values.kind) &&
          (values.duration === 'all' || item.dataset.duration === values.duration) &&
          (values.pace === 'all' || item.dataset.pace === values.pace);
        item.hidden = !matches;
        if (matches) visible += 1;
      });
      count.textContent = `${visible} ${document.documentElement.lang === 'pt-BR' ? (visible === 1 ? 'experiência' : 'experiências') : (visible === 1 ? 'experience' : 'experiences')}`;
      empty.hidden = visible !== 0;
    };
    form.addEventListener('input', update);
    form.querySelector('[data-reset]').addEventListener('click', () => {
      query.value = '';
      selects.forEach((select) => select.value = 'all');
      update();
      query.focus();
    });
  });
</script>

<section class="tripadvisor-section">
  <div class="tripadvisor-intro">
    <div class="tripadvisor-mark" aria-hidden="true"><span>●</span><span>●</span></div>
    <div>
      <p class="eyebrow">Tripadvisor</p>
      <h2>{isPt ? 'Histórias de quem foi.' : 'Stories from those who went.'}</h2>
      <div class="rating-row">
        <strong class="rating-score">4.9</strong>
        <span class="rating-dots" aria-label={isPt ? 'Avaliação excelente no Tripadvisor' : 'Excellent Tripadvisor rating'}>● ● ● ● ●</span>
        <b>{isPt ? 'com base em 156 avaliações' : 'based on 156 traveller reviews'}</b>
      </div>
    </div>
    <a class="button trip-button" href="https://www.tripadvisor.com/Attraction_Review-g303235-d7940404-Reviews-Aguia_Amazonas_Turismo_Day_Tours-Manaus_Amazon_River_State_of_Amazonas.html" target="_blank" rel="noreferrer">{isPt ? 'Ler todas as avaliações' : 'Read all reviews'} ↗</a>
  </div>
  <div class="review-grid">
    <article><span>“</span><p>{isPt ? 'Antonio nos deixou confortáveis e seguros desde o início. Uma experiência inesquecível para toda a família.' : 'Antonio made us feel comfortable and safe from the start. An unforgettable experience for our whole family.'}</p><footer><b>Maren R</b><small>Tripadvisor · May 2026</small></footer></article>
    <article><span>“</span><p>{isPt ? 'Uma experiência única e muito autêntica na Amazônia, com atividades bem planejadas e acolhimento caloroso.' : 'A unique and truly authentic Amazon experience, with thoughtful daily activities and a wonderfully warm welcome.'}</p><footer><b>Roam37002819858</b><small>Tripadvisor · March 2026</small></footer></article>
    <article><span>“</span><p>{isPt ? 'Seis dias incríveis com Antonio na selva. Recomendo absolutamente.' : 'Six amazing days with Antonio in the jungle. Absolutely, highly recommended.'}</p><footer><b>Henry N</b><small>Tripadvisor · May 2026</small></footer></article>
  </div>
  <div class="review-action">
    <img
      src="/images/reviews/tripadvisor-review-qr.webp"
      alt={isPt ? 'Código QR para avaliar a Águia Amazonas no Tripadvisor' : 'QR code to review Águia Amazonas on Tripadvisor'}
      width="135"
      height="200"
      loading="lazy"
    />
    <div>
      <p class="eyebrow">{isPt ? 'Já viajou com Antonio?' : 'Travelled with Antonio?'}</p>
      <h3>{isPt ? 'Compartilhe sua experiência.' : 'Share your experience.'}</h3>
      <p>{isPt ? 'Aponte a câmera para o código ou abra o Tripadvisor para deixar sua avaliação.' : 'Point your camera at the code or open Tripadvisor to leave your review.'}</p>
      <a href="https://www.tripadvisor.com/UserReviewEdit-g303235-d7940404-Aguia_Amazonas_Turismo_Day_Tours-Manaus_Amazon_River_State_of_Amazonas.html" target="_blank" rel="noreferrer">{isPt ? 'Escrever uma avaliação' : 'Write a review'} ↗</a>
    </div>
  </div>
</section>
