---
interface Props { lang?: 'en' | 'pt-BR' }
const { lang = 'en' } = Astro.props;
const isPt = lang === 'pt-BR';
const message = encodeURIComponent(
  isPt
    ? 'Olá Antonio, gostaria de conversar sobre uma viagem à Amazônia.'
    : 'Hello Antonio, I would like to talk about an Amazon journey.',
);
---

<a
  class="floating-contact"
  href={`https://wa.me/5592994587173?text=${message}`}
  target="_blank"
  rel="noreferrer"
  aria-label={isPt ? 'Conversar com Antonio no WhatsApp' : 'Ask Antonio on WhatsApp'}
>
  <svg aria-hidden="true" viewBox="0 0 24 24">
    <path d="M20 11.4a7.7 7.7 0 0 1-8 7.4 8.4 8.4 0 0 1-3.6-.8L4 19.2l1.3-4a7.1 7.1 0 0 1-1-3.8A7.7 7.7 0 0 1 12.2 4 7.7 7.7 0 0 1 20 11.4Z" />
    <path d="M9.1 8.1c.2-.2.5-.2.7 0l1 1.5c.1.2.1.4 0 .6l-.6.7c.5 1 1.3 1.8 2.4 2.3l.7-.7c.2-.1.4-.1.6 0l1.5.9c.2.2.3.5.1.7-.4.7-1 1.1-1.8 1.1-2.7-.1-5.8-3-5.9-5.5 0-.7.4-1.3 1.3-1.6Z" />
  </svg>
  <span>{isPt ? 'Fale com Antonio' : 'Ask Antonio'}</span>
</a>
