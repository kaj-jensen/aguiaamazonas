---
interface Props { lang?: 'en' | 'pt-BR' }
const { lang = 'en' } = Astro.props;
const isPt = lang === 'pt-BR';
---
<header class="site-header">
  <a class="brand" href={isPt ? '/pt/' : '/'} aria-label="Águia Amazonas home">
    <span><strong>Águia Amazonas</strong><small>{isPt ? 'Jornadas autênticas na Amazônia' : 'Authentic Amazon journeys'}</small></span>
  </a>
  <nav class="desktop-nav" aria-label="Primary navigation">
    <a href={isPt ? '/pt/#experiencias' : '/#experiences'}>{isPt ? 'Experiências' : 'Experiences'}</a>
    <a href={isPt ? '/pt/guia-de-viagem-amazonia-brasileira/' : '/brazilian-amazon-travel-guide/'}>{isPt ? 'Guia da Amazônia' : 'Amazon guide'}</a>
    <a href={isPt ? '/pt/sobre/' : '/about/'}>{isPt ? 'Sobre Antonio' : 'Meet Antonio'}</a>
    <a href={isPt ? '/' : '/pt/'} class="language">{isPt ? 'EN' : 'PT'}</a>
    <a class="nav-cta" href="https://wa.me/5592994587173" target="_blank" rel="noreferrer">WhatsApp</a>
  </nav>
  <details class="mobile-nav">
    <summary aria-label={isPt ? 'Abrir menu' : 'Open menu'}>
      <span>{isPt ? 'Menu' : 'Menu'}</span>
      <i aria-hidden="true"></i>
    </summary>
    <nav aria-label={isPt ? 'Navegação principal móvel' : 'Mobile primary navigation'}>
      <a href={isPt ? '/pt/#experiencias' : '/#experiences'}>{isPt ? 'Experiências' : 'Experiences'}</a>
      <a href={isPt ? '/pt/guia-de-viagem-amazonia-brasileira/' : '/brazilian-amazon-travel-guide/'}>{isPt ? 'Guia da Amazônia' : 'Amazon guide'}</a>
      <a href={isPt ? '/pt/sobre/' : '/about/'}>{isPt ? 'Sobre Antonio' : 'Meet Antonio'}</a>
      <a href={isPt ? '/' : '/pt/'}>{isPt ? 'English' : 'Português'}</a>
      <a class="mobile-nav-contact" href="https://wa.me/5592994587173" target="_blank" rel="noreferrer">WhatsApp</a>
    </nav>
  </details>
</header>
