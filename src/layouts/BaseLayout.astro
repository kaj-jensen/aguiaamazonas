---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '../styles/tour-gallery.css';
import '../styles/tour-details.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  lang?: 'en' | 'pt-BR';
}

const { title, description, image, lang = 'en' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const pageTitle = title === 'Águia Amazonas' ? title : `${title} | Águia Amazonas`;
const socialImage = image ? new URL(image, Astro.site) : undefined;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#071c16" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="mask-icon" href="/favicon.svg" color="#0d6a43" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {socialImage && <meta property="og:image" content={socialImage} />}
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header lang={lang} />
    <main><slot /></main>
    <Footer lang={lang} />
  </body>
</html>
