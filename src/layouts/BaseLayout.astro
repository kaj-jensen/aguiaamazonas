---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingContact from '../components/FloatingContact.astro';
import '../styles/global.css';
import '../styles/tour-gallery.css';
import '../styles/tour-details.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  lang?: 'en' | 'pt-BR';
  alternateEn?: string;
  alternatePt?: string;
}

const { title, description, image, imageAlt, lang = 'en', alternateEn, alternatePt } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const pageTitle = title === 'Águia Amazonas' ? title : `${title} | Águia Amazonas`;
const socialImage = new URL(image ?? '/images/amazon-river-hero.png', Astro.site);
const locale = lang === 'pt-BR' ? 'pt_BR' : 'en_US';
const alternateLocale = lang === 'pt-BR' ? 'en_US' : 'pt_BR';
const travelAgencySchema = {
  '@context': 'https://schema.org',
  '@type': 'TravelAgency',
  '@id': new URL('/#travel-agency', Astro.site).href,
  name: 'Águia Amazonas Turismo',
  url: new URL('/', Astro.site).href,
  logo: new URL('/images/brand/aguia-amazonas-mark.svg', Astro.site).href,
  image: new URL('/images/amazon-river-hero.png', Astro.site).href,
  telephone: '+55 92 99458-7173',
  email: 'atnguide@hotmail.com',
  founder: {
    '@type': 'Person',
    name: 'Antonio',
    jobTitle: 'Founder and Amazon expedition guide',
  },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Amazonas, Brazil',
  },
  sameAs: [
    'https://www.tripadvisor.com/Attraction_Review-g303235-d7940404-Reviews-Aguia_Amazonas_Turismo_Day_Tours-Manaus_Amazon_River_State_of_Amazonas.html',
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#071c16" />
    <link rel="canonical" href={canonical} />
    {alternateEn && <link rel="alternate" hreflang="en" href={new URL(alternateEn, Astro.site)} />}
    {alternatePt && <link rel="alternate" hreflang="pt-BR" href={new URL(alternatePt, Astro.site)} />}
    {alternateEn && <link rel="alternate" hreflang="x-default" href={new URL(alternateEn, Astro.site)} />}
    <link rel="icon" href="/favicon.png" type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Águia Amazonas" />
    <meta property="og:locale" content={locale} />
    <meta property="og:locale:alternate" content={alternateLocale} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={imageAlt ?? 'Amazon river and rainforest in Amazonas, Brazil'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={imageAlt ?? 'Amazon river and rainforest in Amazonas, Brazil'} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(travelAgencySchema)}></script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header lang={lang} />
    <main><slot /></main>
    <Footer lang={lang} />
    <FloatingContact lang={lang} />
  </body>
</html>
