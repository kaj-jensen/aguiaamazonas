---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { tours, type Tour } from '../../data/tours';
import { getTourDetail } from '../../data/tourDetails';

export function getStaticPaths() { return tours.map((tour) => ({ params: { slug: tour.slug }, props: { tour } })); }
interface Props { tour: Tour }
const { tour } = Astro.props;
const detail = getTourDetail(tour.slug);
const message = encodeURIComponent(`Hello Antonio, I am interested in the ${tour.name}. Please help me plan the journey.`);
const englishPath = `/experiences/${tour.slug}/`;
const portuguesePath = `/pt/experiencias/${tour.ptSlug}/`;
const pageUrl = new URL(englishPath, Astro.site).href;
const tourSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TouristTrip',
      '@id': `${pageUrl}#tour`,
      name: tour.name,
      description: tour.seoDescription,
      url: pageUrl,
      inLanguage: 'en',
      image: [tour.image, ...(tour.gallery ?? []).map((image) => image.src)].map((image) => new URL(image, Astro.site).href),
      touristType: tour.kind === 'day' ? 'Day tour travellers' : tour.kind === 'lodge' ? 'Jungle lodge travellers' : tour.kind === 'cruise' ? 'Amazon river cruise travellers' : 'Adventure travellers',
      provider: { '@id': new URL('/#travel-agency', Astro.site).href },
      itinerary: {
        '@type': 'ItemList',
        itemListElement: tour.itinerary.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: item.label,
          description: item.text,
        })),
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Águia Amazonas', item: new URL('/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: 'Amazon journeys', item: new URL('/#experiences', Astro.site).href },
        { '@type': 'ListItem', position: 3, name: tour.name, item: pageUrl },
      ],
    },
  ],
};
---
<BaseLayout title={tour.name} description={tour.seoDescription} image={tour.image} imageAlt={tour.imageAlt} alternateEn={englishPath} alternatePt={portuguesePath}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(tourSchema)}></script>
  <section class="tour-hero" style={`--accent:${tour.accent}`}>
    <div class="tour-hero-image"><img src={tour.image} alt={tour.imageAlt} /><div class="image-index">AMZ / {String(tours.indexOf(tour)+1).padStart(2,'0')}</div></div>
    <div class="tour-hero-copy"><p class="eyebrow">{tour.eyebrow}</p><h1>{tour.name}</h1><p>{tour.summary}</p><div class="tour-facts"><div><span>Duration</span><b>{tour.duration}</b></div><div><span>Style</span><b>{tour.group}</b></div></div><a class="button primary" href={`https://wa.me/5592994587173?text=${message}`} target="_blank" rel="noreferrer">Plan this journey</a></div>
  </section>
  <section class="tour-introduction wrap">
    <div class="tour-introduction-copy"><p class="eyebrow">The full picture</p><h2>What this journey<br/>is really like.</h2>{detail.introduction.map((paragraph) => <p>{paragraph}</p>)}</div>
    <aside class="tour-fact-panel"><p class="eyebrow light">At a glance</p>{detail.facts.map((fact) => <div><span>{fact.label}</span><b>{fact.value}</b></div>)}</aside>
  </section>
  <section class="tour-body wrap">
    <aside><p class="eyebrow">What stays with you</p><ul>{tour.highlights.map((item)=><li>{item}</li>)}</ul></aside>
    <div class="itinerary"><p class="eyebrow">The experience</p><h2>A journey shaped<br/>by the living forest.</h2>{tour.itinerary.map((item)=><div class="itinerary-row"><b>{item.label}</b><p>{item.text}</p></div>)}</div>
  </section>
  {tour.gallery && <section class="tour-gallery-section">
    <div class="wrap">
      <div class="tour-gallery-heading"><div><p class="eyebrow">Real moments</p><h2>A closer look at<br/>the journey.</h2></div><p>Photographs from Águia Amazonas journeys show the places, activities and atmosphere that make this particular experience distinctive.</p></div>
      <div class="tour-gallery">{tour.gallery.map((image) => <figure><img src={image.src} alt={image.alt} loading="lazy" /><figcaption>{image.alt}</figcaption></figure>)}</div>
    </div>
  </section>}
  <section class="practical"><div class="wrap"><div class="practical-heading"><p class="eyebrow">Plan with confidence</p><h2>The useful details.</h2></div><div class="practical-list-grid"><div><p class="eyebrow">Included</p><ul>{tour.included.map((item)=><li>{item}</li>)}</ul></div><div><p class="eyebrow">Not included</p><ul>{detail.notIncluded.map((item)=><li>{item}</li>)}</ul></div><div><p class="eyebrow">What to bring</p><ul>{tour.bring.map((item)=><li>{item}</li>)}</ul></div></div><div class="practical-bottom"><div class="know-panel"><p class="eyebrow">Good to know</p><ul>{detail.goodToKnow.map((item)=><li>{item}</li>)}</ul></div><div class="book-panel"><p class="eyebrow light">Made for you</p><h2>Dates, pace and details are personal.</h2><p>Tell Antonio when you will be in Manaus, how many are travelling and what kind of experience you want.</p><a class="button pale" href={`https://wa.me/5592994587173?text=${message}`} target="_blank" rel="noreferrer">Talk on WhatsApp</a><a href="mailto:atnguide@hotmail.com" class="email-link">or email Antonio</a></div></div></div></section>
</BaseLayout>
