---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { tours, type Tour } from '../../../data/tours';
export function getStaticPaths(){return tours.map((tour)=>({params:{slug:tour.ptSlug},props:{tour}}));}
interface Props { tour: Tour }
const { tour } = Astro.props;
const message = encodeURIComponent(`Olá Antonio, tenho interesse em ${tour.ptName}. Pode me ajudar a planejar esta viagem?`);
---
<BaseLayout title={tour.ptName} description={tour.ptSummary} image={tour.image} lang="pt-BR">
  <section class="tour-hero" style={`--accent:${tour.accent}`}><div class="tour-hero-image"><img src={tour.image} alt={tour.ptName}/><div class="image-index">AMZ / {String(tours.indexOf(tour)+1).padStart(2,'0')}</div></div><div class="tour-hero-copy"><p class="eyebrow">{tour.ptEyebrow}</p><h1>{tour.ptName}</h1><p>{tour.ptSummary}</p><div class="tour-facts"><div><span>Duração</span><b>{tour.ptDuration}</b></div><div><span>Estilo</span><b>{tour.ptGroup}</b></div></div><a class="button primary" href={`https://wa.me/5592994587173?text=${message}`} target="_blank" rel="noreferrer">Planejar esta jornada</a></div></section>
  <section class="tour-body wrap"><aside><p class="eyebrow">Momentos marcantes</p><ul>{tour.ptHighlights.map((item)=><li>{item}</li>)}</ul></aside><div class="itinerary"><p class="eyebrow">A experiência</p><h2>Uma jornada guiada<br/>pela floresta viva.</h2>{tour.ptItinerary.map((item)=><div class="itinerary-row"><b>{item.label}</b><p>{item.text}</p></div>)}</div></section>
  <section class="practical"><div class="wrap practical-grid"><div><p class="eyebrow">Incluído</p><ul>{tour.ptIncluded.map((item)=><li>{item}</li>)}</ul></div><div><p class="eyebrow">O que levar</p><ul>{tour.ptBring.map((item)=><li>{item}</li>)}</ul></div><div class="book-panel"><p class="eyebrow light">Feito para você</p><h2>Datas, ritmo e detalhes são pessoais.</h2><p>Conte a Antonio quando estará em Manaus, quantas pessoas viajam e o que deseja viver.</p><a class="button pale" href={`https://wa.me/5592994587173?text=${message}`} target="_blank" rel="noreferrer">Conversar no WhatsApp</a><a href="mailto:atnguide@hotmail.com" class="email-link">ou envie um e-mail</a></div></div></section>
</BaseLayout>
